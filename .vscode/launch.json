{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "🚀 Run Example App",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "${input:exampleApp}",
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🧪 Run Tests",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": [
        "-c",
        "yarn ${input:testTarget}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🔄 Sync Packages",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "sync"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "📱 Show Local IP QR",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "ipqr"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "📸 Setup Page for Screenshot",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "./scripts/screenshot_launch.sh"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "inputs": [
    {
      "id": "exampleApp",
      "type": "pickString",
      "description": "Select example app to run",
      "options": [
        "web-js",
        "next-latest",
        "next-12",
        "react-latest",
        "react-17",
        "designer"
      ]
    },
    {
      "id": "testTarget",
      "type": "pickString",
      "description": "Select package to test",
      "options": [
        { "label": "All",                    "value": "test:all" },
        { "label": "courier-js",             "value": "workspace @trycourier/courier-js run test" },
        { "label": "courier-react",          "value": "workspace @trycourier/courier-react run test" },
        { "label": "courier-react-17",       "value": "workspace @trycourier/courier-react-17 run test" },
        { "label": "courier-ui-inbox",       "value": "workspace @trycourier/courier-ui-inbox run test" },
        { "label": "courier-ui-toast",       "value": "workspace @trycourier/courier-ui-toast run test" }
      ]
    }
  ]
}
