{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "emitDeclarationOnly": false,
    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/__tests__",
    "src/test-setup.ts",
    "node_modules",
    "dist"
  ]
}
