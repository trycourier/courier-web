{
  "name": "courier-web-workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "@trycourier/courier-js",
      "@trycourier/courier-ui-core",
      "@trycourier/courier-ui-inbox",
      "@trycourier/courier-ui-toast",
      "@trycourier/courier-ui-preferences",
      "@trycourier/courier-react-components",
      "@trycourier/courier-react",
      "@trycourier/courier-react-17",
      "@trycourier/courier-vue",
      "examples/*",
      "designer"
    ],
    "nohoist": [
      "angular/@angular/**",
      "angular/@analogjs/**",
      "angular/typescript",
      "angular/zone.js",
      "angular/rxjs"
    ]
  },
  "repository": {
    "url": "https://github.com/trycourier/courier-web"
  },
  "scripts": {
    "build-packages": "yarn exec ./scripts/build-packages",
    "build-packages:ci": "yarn exec ./scripts/build-packages-ci",
    "sync": "yarn exec ./scripts/sync",
    "release": "yarn build-packages:ci && yarn changeset publish",
    "ipqr": "sh ./scripts/ipqr.sh",
    "generate-api-docs": "yarn exec ./scripts/generate-api-docs",
    "test:all": "concurrently -n \"js,inbox,react,react17,vue,toast,prefs\" -c \"blue,green,yellow,cyan,red,magenta,white\" \"yarn workspace @trycourier/courier-js run test\" \"yarn workspace @trycourier/courier-ui-inbox run test\" \"yarn workspace @trycourier/courier-react run test\" \"yarn workspace @trycourier/courier-react-17 run test\" \"yarn workspace @trycourier/courier-vue run test\" \"yarn workspace @trycourier/courier-ui-toast run test\" \"yarn workspace @trycourier/courier-ui-preferences run test\""
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.5",
    "@microsoft/api-extractor": "^7.52.15",
    "@types/node": "20.4.2",
    "concurrently": "8.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "ts-node": "10.9.1",
    "ts-node-dev": "2.0.0",
    "typescript": "5.1.6"
  },
  "resolutions": {
    "lodash": "^4.18.0",
    "fast-uri": "^3.1.1",
    "shell-quote": "^1.8.4",
    "@isaacs/brace-expansion": "^5.0.1",
    "postcss": "^8.5.10",
    "@remix-run/router": "^1.23.2",
    "**/@microsoft/tsdoc-config/ajv": "^8.18.0",
    "**/@rushstack/node-core-library/ajv": "^8.18.0",
    "**/ajv-formats/ajv": "^8.18.0",
    "@microsoft/api-extractor/minimatch": "^10.2.1",
    "@microsoft/api-extractor/diff": "^8.0.3",
    "**/eslint/minimatch": "^3.1.5",
    "**/@eslint/config-array/minimatch": "^3.1.5",
    "**/@eslint/eslintrc/minimatch": "^3.1.5",
    "**/eslint-plugin-import/minimatch": "^3.1.5",
    "**/eslint-plugin-jsx-a11y/minimatch": "^3.1.5",
    "**/eslint-plugin-react/minimatch": "^3.1.5",
    "**/glob/minimatch": "^3.1.5",
    "**/jake/minimatch": "^3.1.5",
    "**/test-exclude/minimatch": "^3.1.5",
    "**/ts-node/diff": "^4.0.4",
    "**/anymatch/picomatch": "^2.3.2",
    "**/jest-util/picomatch": "^2.3.2",
    "**/micromatch/picomatch": "^2.3.2",
    "**/readdirp/picomatch": "^2.3.2",
    "**/@rollup/pluginutils/picomatch": "^4.0.4",
    "**/rollup-plugin-visualizer/picomatch": "^4.0.4",
    "**/tinyglobby/picomatch": "^4.0.4",
    "**/vite/picomatch": "^4.0.4",
    "**/minimatch/brace-expansion": "^1.1.15"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
